# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/

# ─── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Raw dataset — too large for GitHub (22GB, individual files >100MB) ────────
dataset/

# ─── Structurally cleaned parquets — reproducible from raw via eda.clean ───────
structural_clean/

# ─── Large derived parquets — reproducible from pipeline ───────────────────────
# cleaned_data/ contains is_outlier + value_norm enriched parquets
cleaned_data/

# Feature matrices — large (memory_data_train is 226MB)
artifacts/features/*.parquet

# Split parquets — reproducible via eda.make_splits
artifacts/splits/*.parquet

# Score parquets — reproducible via models.train_baseline
artifacts/scores/*.parquet

# ─── Keep these artifacts (small JSON + HTML reports) ─────────────────────────
!artifacts/splits/split_manifest.json
!artifacts/splits/time_splits.json
!artifacts/eda/train_stats.json
!artifacts/eda/summary.json
!artifacts/features/feature_manifest.json
!artifacts/scores/model_summary.json

# ─── Pytest / testing ─────────────────────────────────────────────────────────
.pytest_cache/
pytest_out.txt
*.log

# ─── Reports — keep HTML (generated by build_eda.py) ──────────────────────────
# Plots (PNG) are small, keep them
# reports/eda_report.html is 374KB — fine to include

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db
*.swp
*.swo

# ─── Temp / scratch ───────────────────────────────────────────────────────────
*.tmp
inspect_schema.py
